{
  "name": "queryforge",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "dist-electron/electron/main.js",
  "scripts": {
    "dev": "tsc -p electron/tsconfig.json && concurrently -k \"vite\" \"tsc -w -p electron/tsconfig.json\" \"wait-on http://localhost:5180 && NODE_ENV=development electron .\"",
    "build": "tsc -b && vite build && tsc -p electron/tsconfig.json",
    "dist": "npm run build && electron-builder --mac",
    "preview": "vite preview",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.{ts,tsx}\" \"electron/**/*.ts\"",
    "generate:interview-bank": "node scripts/generate-interview-bank.mjs",
    "generate:wiki-concepts": "node scripts/generate-wiki-concepts.mjs",
    "generate:dsa": "node scripts/generate-dsa-worlds.mjs",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "typecheck": "tsc -b && tsc -p electron/tsconfig.json --noEmit",
    "electron:compile": "tsc -p electron/tsconfig.json"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@tanstack/react-query": "^5.95.2",
    "@tanstack/react-virtual": "^3.13.14",
    "framer-motion": "^12.38.0",
    "monaco-editor": "^0.55.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.2",
    "sql.js": "^1.14.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^29.0.1",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.2",
    "vite": "^8.0.1",
    "vitest": "^4.1.2",
    "wait-on": "^9.0.4"
  }
}
